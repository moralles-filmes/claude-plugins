{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "description": "Bloqueia Edit/Write em arquivos *.sql que contenham anti-patterns RLS críticos",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-sql-antipattern.mjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "description": "Em commits git, roda secret-scan rápido nos arquivos staged",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-commit-secret-scan.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "description": "Após Edit/Write em supabase/migrations/*.sql, sugere rodar /check-rls",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-migration-edit.mjs"
          }
        ]
      }
    ]
  }
}
